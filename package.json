{
  "name": "ai-prescription-validator",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "build": "npm run build -w frontend",
    "seed": "npm run prisma:seed -w backend",
    "db:generate": "npm run prisma:generate -w backend",
    "db:migrate": "npm run prisma:migrate -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
